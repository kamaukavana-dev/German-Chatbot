# Copy this file to ".env" and fill in your keys, then run `npm run dev`.
#
# The AI tutor falls back across providers in this order:
#   Groq (primary) → OpenRouter → Cerebras → Gemini (last resort)

# ---- Groq — https://console.groq.com/keys --------------------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---- OpenRouter — https://openrouter.ai/keys -----------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# ---- Cerebras — https://cloud.cerebras.ai ---------------------------------
# NOTE: model ids are key-specific. Check GET https://api.cerebras.ai/v1/models
# for what YOUR key can use (e.g. gpt-oss-120b, zai-glm-4.7 — both reasoning
# models). A wrong id returns HTTP 404 "model_not_found".
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b

# ---- Gemini (last-resort fallback) — https://aistudio.google.com/apikey ---
# Up to 4 keys, rotated on 429. Needs a billing-enabled / free-tier-eligible
# project (a key with free-tier limit 0 returns RESOURCE_EXHAUSTED).
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_MODEL=gemini-2.0-flash

# ---- Pexels (lesson images) — https://www.pexels.com/api/ -----------------
PEXELS_API_KEY_1=
PEXELS_API_KEY_2=

# Optional:
# PORT=3001
