# Copy this file to ".env" and fill in your key, then run `npm run dev`.

# Required for the AI tutor (get one at https://aistudio.google.com/apikey).
GEMINI_API_KEY=AIza...

# Optional overrides:
# GEMINI_MODEL=gemini-2.5-flash
# PORT=3001

# Required for lesson images (get one free at https://www.pexels.com/api/).
PEXELS_API_KEY=your_pexels_key_here
