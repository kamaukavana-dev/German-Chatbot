# Copy this file to ".env" and fill in your keys, then run `npm run dev`.

# ---- Gemini — get free keys at https://aistudio.google.com/apikey ---------
# Create 4 separate Google AI Studio projects for isolated quotas.
# Default model is gemini-2.0-flash (gemini-1.5-flash is retired).
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=

# ---- Pexels — get free keys at https://www.pexels.com/api/ ----------------
# (2 keys = ~40000 requests/month).
PEXELS_API_KEY_1=
PEXELS_API_KEY_2=

# Optional overrides:
# GEMINI_MODEL=gemini-2.0-flash
# PORT=3001
